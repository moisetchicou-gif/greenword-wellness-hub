/* Style for the tag columns container */
.tag-columns {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between; /* Adjust alignment as needed */
    margin-bottom: 20px; /* Add spacing between the columns and content below */
}

/* Style for each individual tag column */
.tag-column {
    flex: 1;
    max-width: calc(50% - 10px); /* Adjust the width of columns as needed for 2 columns */
    padding: 10px; /* Add padding around each column */
    box-sizing: border-box; /* Include padding in the column's width */
}

/* Style for tag links and text alignment left */
.tag-column a {
    display: block;
    text-decoration: none;
    color: #333; /* Customize the link color */
    text-align: left; /* Align the tag name to the left */
	margin: 0; /* Remove the margin between tags */
   }

/* Responsive adjustments for mobile devices */
@media (max-width: 767px) {
    .tag-columns {
        justify-content: flex-start; /* Align columns to the left on small screens */
    }
    .tag-column {
        max-width: calc(50% - 10px); /* Adjust the width of columns as needed for 2 columns */
    }
}
